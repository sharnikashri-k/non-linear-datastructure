/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     struct ListNode *next;
 * };
 */
struct ListNode* removeNthFromEnd(struct ListNode* head, int n) {
    struct ListNode temp;
    temp.next = head;

    struct ListNode *p=&temp,*q=&temp;
    int i=0;
    while(i<=n){
        p=p->next;
        i++;
    }
    while(p!=NULL){
        p=p->next;
        q=q->next;
    }
     q->next= q->next->next;
     return temp.next;
}
